# =============================================================================
# Filename:  config.toml.example
# Version:   2.0.0
# Objective: Template for SeeVar configuration. bootstrap.sh copies this to
#            config.toml and patches it interactively. You can also edit
#            config.toml directly after installation.
#
# Required sections : [location], [aavso], [planner], [storage], [[seestars]]
# Optional sections : [weather], [notifications], [network]
#                     Leave optional string fields empty ("") to disable them.
# =============================================================================

# -----------------------------------------------------------------------------
# LOCATION — required
# These coordinates are the GPS fallback when the hardware GPS is unavailable.
# maidenhead is also the home-detection trigger: if maidenhead matches
# [network] home_grid the pipeline knows it is at home and expects a NAS.
# -----------------------------------------------------------------------------
[location]
lat            = 51.4779
lon            = -0.0015
elevation      = 46.0
maidenhead     = "IO91WM"
bortle         = 7        # 1 = pristine dark sky, 9 = city centre
horizon_limit  = 30.0     # minimum target altitude in degrees
moon_avoidance = 30.0     # minimum angular distance from moon in degrees

# Manual obstruction boxes are always applied as safety floors, even when a
# scanned data/horizon_mask.json profile exists. Use these for houses, roofs,
# trees, balconies, or any sector where an experimental scan is not trustworthy.
#
# [[location.obstructions]]
# label    = "west_house_roof"
# az_start = 225.0
# az_end   = 355.0     # wrap-around sectors are allowed, e.g. 330 -> 20
# min_alt  = 70.0

# -----------------------------------------------------------------------------
# HORIZON — optional
# profile_enabled : true uses the configured profile_path when present.
# profile_path    : relative paths are resolved from the SeeVar repository root.
# profile_required: true fails planning if the profile is missing or unreadable.
# safety_floor_deg: hard minimum altitude before manual obstructions are applied.
#                  [location].horizon_limit is also honored as a safety floor.
# -----------------------------------------------------------------------------
[horizon]
profile_enabled = true
profile_path = "data/horizon_mask.json"
profile_required = false
safety_floor_deg = 15.0

# -----------------------------------------------------------------------------
# AAVSO — required
# observer_code : your official AAVSO observer code (e.g. REDA)
# webobs_session_cookie : optional — authenticated apps.aavso.org session cookie
#                         for live WebObs submission automation.
#                         Preferred format:
#                         "app2_session=...; canary=false"
# webobs_token  : optional legacy fallback — if set and webobs_session_cookie
#                 is empty, SeeVar treats this as the raw app2_session value.
# target_tool_api_key : optional — needed for live AAVSO Target Tool API access.
#                       This is separate from WebObs login/cookie submission.
# target_key          : legacy alias for target_tool_api_key.
#                       The bundled seed catalog works without these keys.
# -----------------------------------------------------------------------------
[aavso]
observer_code = "YOUR_CODE_HERE"
webobs_session_cookie = ""
webobs_token  = ""
auto_submit = true
sanity_enabled = true
max_mag_error = 0.5
sanity_margin_mag = 1.0
max_peak_adu = 58000.0
target_tool_api_key = ""
target_key    = ""

# -----------------------------------------------------------------------------
# BAA — optional
# Used only for the BAA-modified AAVSO Extended export variant.
# observer_code can differ from your AAVSO observer code.
# Leave empty to let SeeVar derive sane defaults from [location] and [[seestars]].
# -----------------------------------------------------------------------------
[baa]
observer_code = ""
telescope = ""
camera    = ""

# -----------------------------------------------------------------------------
# PLANNER — required
# sun_altitude_limit : astronomical darkness threshold in degrees (-18.0)
# simulation_mode    : true = run without hardware (development only)
#                      Always false for real observations.
# -----------------------------------------------------------------------------
[planner]
sun_altitude_limit = -18.0
cadence_divisor      = 20    # period / cadence_divisor = observation interval (1/20th rule)
cadence_fallback_days = 3.0   # fallback cadence (days) for targets without a known period
fleet_mode         = "single" # single = one shared queue, split = divide when 2+ scopes are active, auto = choose by active scope count
simulation_mode    = false
secondary_catalogs = []       # optional filler imaging catalogs: ["messier", "caldwell", "sharpless", "herschel400"]
secondary_max_targets = 0     # 0 = no cap once enabled
secondary_duration_sec = 900  # per-object imaging block for secondary catalogs

# -----------------------------------------------------------------------------
# FLIGHT — optional
# A7 pointing verification must fail fast. If it cannot solve a 2s verification
# frame in roughly half a minute, the target is probably clouded, blocked, or
# off-field; move on instead of burning the night.
# For quick pre-alignment before a session, run:
#   .venv/bin/python dev/tools/telescope/prealign_pointing.py --points 3 --exposure-sec 5
# -----------------------------------------------------------------------------
[flight]
alpaca_port                       = 32323
alpaca_client_id                  = 42
gain                              = 80
settle_seconds                    = 8
pointing_verify_exposure_sec       = 2.0
pointing_plate_solve_timeout_sec   = 35
pointing_plate_solve_cpulimit_sec  = 30
pointing_plate_solve_radius_deg    = 5.0
pointing_plate_solve_downsample    = 1
pointing_tolerance_arcmin          = 12.0
pointing_max_retries               = 2
pointing_gross_error_arcmin        = 180.0
pointing_gross_max_retries         = 1
pointing_accept_target_in_frame    = true
pointing_edge_margin_px            = 250
verify_retention_sets             = 40
pointing_model_enabled             = true
pointing_model_max_age_hours       = 12.0
frame_retry_limit                  = 0

# -----------------------------------------------------------------------------
# STORAGE — required
# lifeboat_dir : local fallback when RAID1 / NAS is not available
# primary_dir  : main archive destination (RAID1 mount or local)
# -----------------------------------------------------------------------------
[storage]
lifeboat_dir  = "~/seevar/data/local_buffer"
primary_dir   = "~/seevar/data/local_buffer"
target_dir    = "~/seevar/data"
sequence_dir  = "~/seevar/data/sequences"
comp_star_dir = "~/seevar/data/comp_stars"

# -----------------------------------------------------------------------------
# WEATHER — optional
# Multi-source: open-meteo + MET Norway/Yr.no + Clear Outside + optional KNMI.
# All thresholds are tunable here — no code changes required.
# fog_abort = false disables the fog veto entirely (not recommended).
# Clouds are science no-go. Rain/fog/thunder/wind are hard aborts.
# -----------------------------------------------------------------------------
[weather]
max_precip_mm      = 0.5    # mm/hr   — rain hard abort
max_wind_kmh       = 30.0   # km/h    — wind hard abort
max_cloud_low_pct   = 30.0  # %       — low cloud science no-go
max_cloud_mid_pct   = 50.0  # %       — mid cloud science no-go
max_cloud_high_pct  = 70.0  # %       — high cloud science no-go
max_cloud_total_pct = 70.0  # %       — total cloud science no-go
max_humidity_pct   = 90.0   # %       — humidity warning only (HUMID) — dew heater cue
fog_abort          = true   # bool    — any fog reading aborts the session

# -----------------------------------------------------------------------------
# POSTFLIGHT — optional
# Caps plate solving so a bad roof/cloud frame cannot pin the accountant for
# hours. Candidate order is stack first, then newest calibrated single frames.
# -----------------------------------------------------------------------------
[postflight]
max_plate_solve_candidates = 3
plate_solve_timeout_sec    = 90
plate_solve_cpulimit_sec   = 75
auto_stage_reports         = true
report_mirror_dir          = "/mnt/astronas/reports"
auto_park                  = true
auto_shutdown_scope        = false

# -----------------------------------------------------------------------------
# CALIBRATION — optional
# Darks are reusable across equivalent Seestar models, but only for matching
# exposure/gain and a nearby camera temperature bin. Tighten this if dark current
# mismatch becomes visible; loosen only for emergency beta recovery.
# -----------------------------------------------------------------------------
[calibration]
dark_temp_tolerance_c = 4.0

# -----------------------------------------------------------------------------
# NOTIFICATIONS — optional
# Create a Telegram bot via @BotFather to receive session alerts.
# Leave both fields empty to disable notifications entirely.
# -----------------------------------------------------------------------------
[notifications]
telegram_bot_token = ""
telegram_chat_id   = ""

# -----------------------------------------------------------------------------
# NETWORK — optional
# Required only if you have a NAS on your home network.
# home_grid must match [location] maidenhead for NAS detection to activate.
# If you are at a remote site (maidenhead != home_grid) the NAS is skipped.
# -----------------------------------------------------------------------------
[network]
nas_ip    = ""
nas_port  = 445
home_grid = "IO91WM"

# -----------------------------------------------------------------------------
# FLEET — required
# One [[seestars]] entry per telescope.
# model : must match a file in core/hardware/models/ (S30, S30-Pro, S50)
# ip    : telescope IP address on your local network — set TBD until known
# mount : altaz for all current Seestar units
#
# The bootstrap telescope questionnaire fills in the first entry.
# Add further telescopes by copying this block.
# -----------------------------------------------------------------------------
[[seestars]]
name  = "MyTelescope"
model = "S30-Pro"
ip    = "TBD"
mount = "altaz"

# [[seestars]]
# name  = "Anna"
# model = "S30-Pro"
# ip    = "TBD"
# mount = "altaz"

# [[seestars]]
# name  = "Henrietta"
# model = "S50"
# ip    = "TBD"
# mount = "altaz"

# -----------------------------------------------------------------------------
# KNMI — optional but recommended for Netherlands observers
# Real 10-minute measured data from the nearest KNMI weather station.
# Register for a free API key at: https://developer.dataplatform.knmi.nl/register/
# Find your nearest station ID via:
#   https://api.dataplatform.knmi.nl/edr/v1/collections/10-minute-in-situ-meteorological-observations/locations
# -----------------------------------------------------------------------------
[knmi]
edr_api_key   = ""                  # Your personal EDR API key
station_id    = "0-20000-0-06240"   # Schiphol Airport (nearest to Haarlem)
station_name  = "Schiphol"          # Human-readable label for logs
okta_limit    = 6                   # Cloud cover abort threshold (0-9 oktas)
vv_limit      = 5000                # Visibility abort threshold (metres)
ww_rain_limit = 50                  # Present weather code >= 50 = rain abort
ww_fog_limit  = 10                  # Present weather code >= 10 = fog warning
[astrometry_net]
api_key = ""
base_url = "https://nova.astrometry.net/api/"
enabled = false


[mission]
max_targets = 0  # 0 = no cap; set to e.g. 5 for short test nights
